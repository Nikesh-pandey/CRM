# Copy this file to ".env" and fill in real values. ".env" is git-ignored.

# Database connection
DB_URL=jdbc:mysql://localhost:3306/mango_diyalo
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# JWT signing secret — must be a Base64-encoded key of at least 256 bits (HS256).
# Generate one with:  openssl rand -base64 32
JWT_SECRET=replace_with_a_base64_encoded_256_bit_secret
# Token lifetime in milliseconds (default 24h).
JWT_EXPIRATION=86400000
